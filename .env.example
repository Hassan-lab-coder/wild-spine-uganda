NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://www.wildspineuganda.com
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=
YANDEX_SITE_VERIFICATION=

# Optional IndexNow key override. The project already includes a public fallback key
# served at /indexnow-key.txt, so this is usually not needed.
INDEXNOW_KEY=

# Required to call POST /api/indexnow from a private script or cron.
INDEXNOW_SECRET=

# Optional lead email notifications through Resend.
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=reservations@wildspineuganda.com
LEAD_NOTIFICATION_FROM=Wild Spine <reservations@wildspineuganda.com>
ADMIN_REPLY_FROM=Wild Spine <reservations@wildspineuganda.com>

# Required for server-side writes from Resend inbound webhooks.
SUPABASE_SERVICE_ROLE_KEY=

# Optional payment link providers. Admin payment requests use these when enabled.
# Release guard: keep false until a controlled live-payment acceptance test is approved.
PAYMENTS_ENABLED=false
STRIPE_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
TAZAPAY_API_KEY=
TAZAPAY_API_SECRET=
# Use sandbox with sandbox credentials while testing. Set live only after KYB approval
# and after generating live keys from https://dashboard.tazapay.com.
TAZAPAY_ENVIRONMENT=
TAZAPAY_DEFAULT_CUSTOMER_COUNTRY=US
TAZAPAY_WEBHOOK_SECRET=
TAZAPAY_WEBHOOK_TOLERANCE_SECONDS=600
# Safety escape hatch for deliberate sandbox testing on a production deployment.
# Leave false when accepting real customer payments.
TAZAPAY_ALLOW_SANDBOX_IN_PRODUCTION=false
# Optional endpoint override. Leave blank unless Tazapay support gives you a custom base URL.
TAZAPAY_BASE_URL=

# Required for secured automation cron:
# POST /api/automation/send-due with Authorization: Bearer <AUTOMATION_SECRET>
AUTOMATION_SECRET=
# Vercel Cron sends this value as a Bearer token. It may match AUTOMATION_SECRET.
CRON_SECRET=

# Add this token to the Resend webhook URL:
# https://your-domain.com/api/resend-inbound?token=your-secret-token
INBOUND_WEBHOOK_TOKEN=

# Durable abuse protection (Upstash Redis REST).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cloudflare Turnstile. Enable required mode only after both keys are configured.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TURNSTILE_REQUIRED=false

# Optional operational alert destination (Slack/Teams/custom webhook).
ALERT_WEBHOOK_URL=
# Used as a Bearer token when ALERT_WEBHOOK_URL points to /api/operations/alert.
ALERT_WEBHOOK_SECRET=
